docs/superpowers/plans/

# Deprecated external-API key documentation — BIKO uses local
# MedGemma via Ollama and needs no external LLM keys. NCBI_API_KEY
# is optional for rate-limit relief only and should live in .env.
docs/API_KEYS.md

# Real patient data — do NOT commit. Any VCF or derived report from a
# real sample is PHI. Synthetic demo VCFs are explicitly whitelisted
# below. Everything else in data/sample_vcf/ is treated as patient data.
data/sample_vcf/*
!data/sample_vcf/demo_variants.vcf
!data/sample_vcf/demo_variants_grch38.vcf
!data/sample_vcf/demo_variants_grch38_annotated.vcf
